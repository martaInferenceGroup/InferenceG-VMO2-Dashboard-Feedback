# Copy this to secrets.toml for local dev, or paste into Streamlit Cloud Secrets
# You only need ONE notification method — pick whichever is easiest for you.

# Client password (shared with clients to access dashboards)
client_password = "change-me-client"

# Reviewer password (only internal team — for Reviewer Panel)
reviewer_password = "change-me-reviewer"

# ─── OPTION 1: Microsoft Teams (recommended if you use Teams) ───────────────
# Create a webhook: Teams channel → ••• → Connectors → Incoming Webhook → copy URL
[teams]
webhook_url = "https://your-org.webhook.office.com/webhookb2/..."

# ─── OPTION 2: Resend.com (recommended if you want email, no Gmail needed) ──
# Sign up free at https://resend.com → API Keys → Create → copy key
# Free tier: 100 emails/day, sends to any email address
[resend]
api_key = "re_xxxxxxxxxxxx"
notify_to = "your-work-email@company.com"
# from_email uses Resend's default unless you verify your own domain
# from_email = "VMO2 Dashboards <dashboards@yourdomain.com>"

# ─── OPTION 3: SMTP (Gmail, Outlook, company mail server) ───────────────────
# Gmail: smtp.gmail.com:587 + app password
# Outlook/O365: smtp.office365.com:587 (may be blocked by IT)
# [email]
# smtp_host = "smtp.gmail.com"
# smtp_port = 587
# smtp_user = "your-email@gmail.com"
# smtp_pass = "your-app-password"
# notify_to = "your-email@gmail.com"
